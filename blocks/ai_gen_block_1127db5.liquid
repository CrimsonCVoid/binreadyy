{% doc %}
  @prompt
    Fix the Buy Now button in the AI-generated section that incorrectly shows "Sold out". The button should pull live product availability data instead of showing a hardcoded sold out state. Make the button functional so it reflects actual inventory and allows customers to purchase.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-buy-now-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
  }

  .ai-buy-now-button-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    padding: {{ block.settings.button_padding }}px {{ block.settings.button_padding | times: 1.5 }}px;
    background-color: {{ block.settings.button_color }};
    color: {{ block.settings.button_text_color }};
    border: none;
    border-radius: {{ block.settings.border_radius }}px;
    font-size: {{ block.settings.font_size }}px;
    font-weight: {{ block.settings.font_weight }};
    text-decoration: none;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .ai-buy-now-button-{{ ai_gen_id }}:hover:not(:disabled) {
    background-color: {{ block.settings.button_hover_color }};
    color: {{ block.settings.button_hover_text_color }};
  }

  .ai-buy-now-button-{{ ai_gen_id }}:disabled {
    background-color: {{ block.settings.sold_out_bg_color }};
    color: {{ block.settings.sold_out_text_color }};
    cursor: not-allowed;
    opacity: 0.6;
  }

  @media screen and (max-width: 749px) {
    .ai-buy-now-{{ ai_gen_id }} {
      width: 100%;
    }
  }
{% endstyle %}

<div class="ai-buy-now-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if product %}
    {% if product.available %}
      <button
        type="button"
        class="ai-buy-now-button-{{ ai_gen_id }}"
        data-product-id="{{ product.id }}"
        data-variant-id="{{ product.selected_or_first_available_variant.id }}"
        onclick="window.location.href='/cart/{{ product.selected_or_first_available_variant.id }}:1?return_to=/checkout'"
      >
        {{ block.settings.button_text }}
      </button>
    {% else %}
      <button
        type="button"
        class="ai-buy-now-button-{{ ai_gen_id }}"
        disabled
      >
        {{ block.settings.sold_out_text }}
      </button>
    {% endif %}
  {% else %}
    <button
      type="button"
      class="ai-buy-now-button-{{ ai_gen_id }}"
      disabled
    >
      {{ block.settings.button_text }}
    </button>
  {% endif %}
</div>

{% schema %}
{
  "name": "Buy now button",
  "settings": [
    {
      "type": "header",
      "content": "Button text"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Buy now"
    },
    {
      "type": "text",
      "id": "sold_out_text",
      "label": "Sold out text",
      "default": "Sold out"
    },
    {
      "type": "header",
      "content": "Button style"
    },
    {
      "type": "color",
      "id": "button_color",
      "label": "Background color",
      "default": "#F5612A"
    },
    {
      "type": "color",
      "id": "button_hover_color",
      "label": "Hover background color",
      "default": "#D94F1E"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Text color",
      "default": "#FAF8F2"
    },
    {
      "type": "color",
      "id": "button_hover_text_color",
      "label": "Hover text color",
      "default": "#FAF8F2"
    },
    {
      "type": "color",
      "id": "sold_out_bg_color",
      "label": "Sold out background color",
      "default": "#CCCCCC"
    },
    {
      "type": "color",
      "id": "sold_out_text_color",
      "label": "Sold out text color",
      "default": "#666666"
    },
    {
      "type": "range",
      "id": "font_size",
      "label": "Font size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "select",
      "id": "font_weight",
      "label": "Font weight",
      "options": [
        {
          "value": "400",
          "label": "Normal"
        },
        {
          "value": "500",
          "label": "Medium"
        },
        {
          "value": "600",
          "label": "Semi-bold"
        },
        {
          "value": "700",
          "label": "Bold"
        }
      ],
      "default": "600"
    },
    {
      "type": "range",
      "id": "button_padding",
      "label": "Padding",
      "min": 8,
      "max": 24,
      "step": 2,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 8
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    }
  ],
  "presets": [
    {
      "name": "Buy now button"
    }
  ]
}
{% endschema %}
