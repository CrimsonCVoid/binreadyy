{% doc %}
  @prompt
    Create a clean, minimal side-by-side image comparison section to be placed just below the Hero section on the homepage. The section should display two images next to each other with a short caption or label beneath each image. The left image should show "Ready Eddie Up = Bin is Full" and the right should show "Ready Eddie Down = Bin is Empty". The section should have a simple, modern look with heading text above the two images that reads "Ready Eddie drops down when they empty your bin," and should be fully responsive (stacking vertically on mobile). All images, labels, and heading text should be customizable via theme editor settings. Keep the section compact/small in height — it's meant to be a quick visual explainer, not a full banner.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-image-comparison-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: {{ block.settings.section_padding_top }}px 20px {{ block.settings.section_padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-image-comparison__container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
    width: 100%;
  }

  .ai-image-comparison__heading-{{ ai_gen_id }} {
    text-align: {{ block.settings.heading_alignment }};
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.heading_size }}px;
    margin: 0 0 {{ block.settings.heading_spacing }}px;
    line-height: 1.3;
  }

  .ai-image-comparison__grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: {{ block.settings.image_gap }}px;
    align-items: start;
  }

  .ai-image-comparison__item-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.caption_spacing }}px;
  }

  .ai-image-comparison__image-wrapper-{{ ai_gen_id }} {
    width: 100%;
    overflow: hidden;
    border-radius: {{ block.settings.image_border_radius }}px;
    background-color: #f4f4f4;
  }

  .ai-image-comparison__image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
  }

  .ai-image-comparison__image-wrapper-{{ ai_gen_id }} svg {
    width: 100%;
    height: auto;
    display: block;
    min-height: 200px;
  }

  .ai-image-comparison__caption-{{ ai_gen_id }} {
    text-align: {{ block.settings.caption_alignment }};
    color: {{ block.settings.caption_color }};
    font-size: {{ block.settings.caption_size }}px;
    line-height: 1.4;
  }

  @media screen and (max-width: 749px) {
    .ai-image-comparison__grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: {{ block.settings.mobile_gap }}px;
    }

    .ai-image-comparison__heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.8 }}px;
    }

    .ai-image-comparison__caption-{{ ai_gen_id }} {
      font-size: {{ block.settings.caption_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<image-comparison-{{ ai_gen_id }}
  class="ai-image-comparison-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-image-comparison__container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <h2 class="ai-image-comparison__heading-{{ ai_gen_id }}">
        {{ block.settings.heading }}
      </h2>
    {% endif %}

    <div class="ai-image-comparison__grid-{{ ai_gen_id }}">
      <div class="ai-image-comparison__item-{{ ai_gen_id }}">
        <div class="ai-image-comparison__image-wrapper-{{ ai_gen_id }}">
          {% if block.settings.image_left %}
            <img
              src="{{ block.settings.image_left | image_url: width: 800 }}"
              alt="{{ block.settings.image_left.alt | escape }}"
              loading="lazy"
              width="{{ block.settings.image_left.width }}"
              height="{{ block.settings.image_left.height }}"
              class="ai-image-comparison__image-{{ ai_gen_id }}"
            >
          {% else %}
            {{ 'product-1' | placeholder_svg_tag }}
          {% endif %}
        </div>
        {% if block.settings.caption_left != blank %}
          <div class="ai-image-comparison__caption-{{ ai_gen_id }}">
            {{ block.settings.caption_left }}
          </div>
        {% endif %}
      </div>

      <div class="ai-image-comparison__item-{{ ai_gen_id }}">
        <div class="ai-image-comparison__image-wrapper-{{ ai_gen_id }}">
          {% if block.settings.image_right %}
            <img
              src="{{ block.settings.image_right | image_url: width: 800 }}"
              alt="{{ block.settings.image_right.alt | escape }}"
              loading="lazy"
              width="{{ block.settings.image_right.width }}"
              height="{{ block.settings.image_right.height }}"
              class="ai-image-comparison__image-{{ ai_gen_id }}"
            >
          {% else %}
            {{ 'product-1' | placeholder_svg_tag }}
          {% endif %}
        </div>
        {% if block.settings.caption_right != blank %}
          <div class="ai-image-comparison__caption-{{ ai_gen_id }}">
            {{ block.settings.caption_right }}
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</image-comparison-{{ ai_gen_id }}>

<script>
  (function() {
    class ImageComparison{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
      }
    }

    customElements.define('image-comparison-{{ ai_gen_id }}', ImageComparison{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Image comparison",
  "settings": [
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading text",
      "default": "Ready Eddie drops down when they empty your bin"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading size",
      "min": 16,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 28
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#1A1A17"
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "Heading alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "heading_spacing",
      "label": "Space below heading",
      "min": 10,
      "max": 60,
      "step": 5,
      "unit": "px",
      "default": 30
    },
    {
      "type": "header",
      "content": "Left image"
    },
    {
      "type": "image_picker",
      "id": "image_left",
      "label": "Image"
    },
    {
      "type": "inline_richtext",
      "id": "caption_left",
      "label": "Caption",
      "default": "Ready Eddie Up = Bin is Full"
    },
    {
      "type": "header",
      "content": "Right image"
    },
    {
      "type": "image_picker",
      "id": "image_right",
      "label": "Image"
    },
    {
      "type": "inline_richtext",
      "id": "caption_right",
      "label": "Caption",
      "default": "Ready Eddie Down = Bin is Empty"
    },
    {
      "type": "header",
      "content": "Caption style"
    },
    {
      "type": "range",
      "id": "caption_size",
      "label": "Caption size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "color",
      "id": "caption_color",
      "label": "Caption color",
      "default": "#1A1A17"
    },
    {
      "type": "select",
      "id": "caption_alignment",
      "label": "Caption alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "caption_spacing",
      "label": "Space between image and caption",
      "min": 5,
      "max": 30,
      "step": 5,
      "unit": "px",
      "default": 15
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Maximum width",
      "min": 600,
      "max": 1400,
      "step": 100,
      "unit": "px",
      "default": 1000
    },
    {
      "type": "range",
      "id": "image_gap",
      "label": "Gap between images",
      "min": 10,
      "max": 80,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "mobile_gap",
      "label": "Gap on mobile",
      "min": 10,
      "max": 60,
      "step": 5,
      "unit": "px",
      "default": 30
    },
    {
      "type": "range",
      "id": "image_border_radius",
      "label": "Image border radius",
      "min": 0,
      "max": 30,
      "step": 2,
      "unit": "px",
      "default": 8
    },
    {
      "type": "header",
      "content": "Section spacing"
    },
    {
      "type": "range",
      "id": "section_padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "section_padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#FAF8F2"
    }
  ],
  "presets": [
    {
      "name": "Image comparison"
    }
  ]
}
{% endschema %}
