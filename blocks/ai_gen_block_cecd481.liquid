    },
    {
      "type": "checkbox",
      "id": "enable_dynamic_checkout",
      "label": "Enable dynamic checkout",
      "info": "Legacy setting, no longer used.",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Buy now button"
    }
  ]
}
{% endschema %}
