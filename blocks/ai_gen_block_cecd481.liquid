{% doc %}
  @prompt
    Fix the "sold out" display issue in the AI-generated Buy Now button block. The product has inventory in all variants but the button is showing as sold out. Create a Buy Now button block that correctly checks variant.available and product.available using Shopify Liquid to show the correct state - never hardcoded sold out.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-buy-now-button-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
  }

  .ai-buy-now-button__wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
  }

  .ai-buy-now-button__btn-{{ ai_gen_id }} {
    width: 100%;
    padding: {{ block.settings.button_padding }}px {{ block.settings.button_padding | times: 1.5 }}px;
    background-color: {{ block.settings.button_color }};
    color: {{ block.settings.button_text_color }};
    border: none;
    border-radius: {{ block.settings.border_radius }}px;
    font-size: {{ block.settings.font_size }}px;
    font-weight: {{ block.settings.font_weight }};
    text-align: center;
    cursor: pointer;
    transition: all 0.3s ease;
    text-decoration: none;
    display: inline-block;
  }

  .ai-buy-now-button__btn-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_color }};
    color: {{ block.settings.button_hover_text_color }};
  }

  .ai-buy-now-button__btn-{{ ai_gen_id }}--sold-out {
    background-color: {{ block.settings.sold_out_bg_color }};
    color: {{ block.settings.sold_out_text_color }};
    cursor: not-allowed;
    opacity: 0.7;
  }

  .ai-buy-now-button__btn-{{ ai_gen_id }}--sold-out:hover {
    background-color: {{ block.settings.sold_out_bg_color }};
    color: {{ block.settings.sold_out_text_color }};
  }
{% endstyle %}

<div
  class="ai-buy-now-button-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-buy-now-button__wrapper-{{ ai_gen_id }}">
    {% if product %}
      {% liquid
        assign current_variant = product.selected_or_first_available_variant
        assign is_available = false
        
        if current_variant.available
          assign is_available = true
        endif
      %}

      {% if is_available %}
        <button
          type="submit"
          name="add"
          class="ai-buy-now-button__btn-{{ ai_gen_id }}"
          {% if block.settings.enable_dynamic_checkout %}
            form="product-form-{{ product.id }}"
          {% endif %}
        >
          {{ block.settings.button_text }}
        </button>
      {% else %}
        <button
          type="button"
          class="ai-buy-now-button__btn-{{ ai_gen_id }} ai-buy-now-button__btn-{{ ai_gen_id }}--sold-out"
          disabled
        >
          {{ block.settings.sold_out_text }}
        </button>
      {% endif %}
    {% else %}
      <button
        type="button"
        class="ai-buy-now-button__btn-{{ ai_gen_id }}"
      >
        {{ block.settings.button_text }}
      </button>
    {% endif %}
  </div>
</div>

<script>
  (function() {
    class BuyNowButton{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.button = this.querySelector('.ai-buy-now-button__btn-{{ ai_gen_id }}');
      }

      connectedCallback() {
        if (!this.button) return;

        const productForm = document.querySelector('product-form');
        if (!productForm) return;

        const variantPicker = productForm.querySelector('variant-selects, variant-radios');
        if (!variantPicker) return;

        variantPicker.addEventListener('change', () => {
          this.updateButton();
        });

        this.updateButton();
      }

      updateButton() {
        const productForm = document.querySelector('product-form');
        if (!productForm) return;

        const variantInput = productForm.querySelector('[name="id"]');
        if (!variantInput) return;

        const variantId = variantInput.value;
        const productData = this.getProductData();
        
        if (!productData || !productData.variants) return;

        const selectedVariant = productData.variants.find(v => v.id == variantId);
        
        if (!selectedVariant) return;

        const isAvailable = selectedVariant.available;
        const buttonText = '{{ block.settings.button_text }}';
        const soldOutText = '{{ block.settings.sold_out_text }}';

        if (isAvailable) {
          this.button.textContent = buttonText;
          this.button.disabled = false;
          this.button.classList.remove('ai-buy-now-button__btn-{{ ai_gen_id }}--sold-out');
          this.button.type = 'submit';
        } else {
          this.button.textContent = soldOutText;
          this.button.disabled = true;
          this.button.classList.add('ai-buy-now-button__btn-{{ ai_gen_id }}--sold-out');
          this.button.type = 'button';
        }
      }

      getProductData() {
        const productJson = document.querySelector('[data-product-json]');
        if (!productJson) return null;
        
        try {
          return JSON.parse(productJson.textContent);
        } catch (e) {
          const scriptTag = document.querySelector('script[type="application/json"][data-product-json]');
          if (scriptTag) {
            return JSON.parse(scriptTag.textContent);
          }
          return null;
        }
      }
    }

    customElements.define('buy-now-button-{{ ai_gen_id }}', BuyNowButton{{ ai_gen_id }});
  })();
</script>

