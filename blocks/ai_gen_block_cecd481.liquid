{% doc %}
  @prompt
    Fix the "sold out" display issue in the AI-generated Buy Now button block. The product has inventory in all variants but the button is showing as sold out. Create a Buy Now button block that correctly checks variant.available and product.available using Shopify Liquid to show the correct state - never hardcoded sold out.
{% enddoc %}
{%- comment -%}
  Rewritten 2026-07: the AI-generated version rendered a dead <button> on the
  homepage (no `product` in scope, and its script targeted Dawn elements this
  theme doesn't have). Now a native flow with zero JS:
    - cart already has items  -> plain link to /checkout
    - cart empty              -> POST /cart/add with return_to=/checkout
  Product resolution: block setting -> page product -> theme LCP handle.
{%- endcomment -%}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{%- assign buy_product = all_products[block.settings.product] -%}
{%- if buy_product == blank and product != blank -%}
  {%- assign buy_product = product -%}
{%- endif -%}
{%- if buy_product == blank -%}
  {%- assign buy_product = all_products[settings.lcp_product_handle] -%}
{%- endif -%}
{%- assign current_variant = buy_product.selected_or_first_available_variant -%}

{% style %}
  .ai-buy-now-button-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
  }

  .ai-buy-now-button__btn-{{ ai_gen_id }} {
    width: 100%;
    padding: {{ block.settings.button_padding }}px {{ block.settings.button_padding | times: 1.5 }}px;
    background-color: {{ block.settings.button_color }};
    color: {{ block.settings.button_text_color }};
    border: none;
    border-radius: {{ block.settings.border_radius }}px;
    font-size: {{ block.settings.font_size }}px;
    font-weight: {{ block.settings.font_weight }};
    font-family: inherit;
    text-align: center;
    cursor: pointer;
    transition: all 0.3s ease;
    text-decoration: none;
    display: inline-block;
    box-sizing: border-box;
  }

  .ai-buy-now-button__btn-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_color }};
    color: {{ block.settings.button_hover_text_color }};
  }

  .ai-buy-now-button__btn-{{ ai_gen_id }}--sold-out {
    background-color: {{ block.settings.sold_out_bg_color }};
    color: {{ block.settings.sold_out_text_color }};
    cursor: not-allowed;
    opacity: 0.7;
  }

  .ai-buy-now-button__btn-{{ ai_gen_id }}--sold-out:hover {
    background-color: {{ block.settings.sold_out_bg_color }};
    color: {{ block.settings.sold_out_text_color }};
  }
{% endstyle %}

<div class="ai-buy-now-button-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {%- if cart.item_count > 0 -%}
    <a href="/checkout" class="ai-buy-now-button__btn-{{ ai_gen_id }}">
      {{ block.settings.button_text }}
    </a>
  {%- elsif current_variant and current_variant.available -%}
    <form action="/cart/add" method="post">
      <input type="hidden" name="id" value="{{ current_variant.id }}" />
      <input type="hidden" name="quantity" value="1" />
      <input type="hidden" name="return_to" value="/checkout" />
      <button type="submit" class="ai-buy-now-button__btn-{{ ai_gen_id }}">
        {{ block.settings.button_text }}
      </button>
    </form>
  {%- else -%}
    <button
      type="button"
      class="ai-buy-now-button__btn-{{ ai_gen_id }} ai-buy-now-button__btn-{{ ai_gen_id }}--sold-out"
      disabled
    >
      {{ block.settings.sold_out_text }}
    </button>
  {%- endif -%}
</div>

