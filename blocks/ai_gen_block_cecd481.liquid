      "default": "#D94F1E"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Text",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "button_hover_text_color",
      "label": "Hover text",
      "default": "#FFFFFF"
    },
    {
      "type": "range",
      "id": "font_size",
