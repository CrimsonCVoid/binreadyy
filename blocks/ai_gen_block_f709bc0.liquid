{% doc %}
  @prompt
    Create a custom announcement bar section for a Shopify theme. The announcement bar should display the message "Free shipping on all orders" and be positioned at the very top of the page, inside the header. It should have customizable settings including: announcement text, background color, text color, and the ability to show/hide the bar. Style it to be clean and minimal, matching a simple and functional store design. Make it a standalone section that can be added to the theme header group.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-announcement-bar-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.background_color }};
    color: {{ block.settings.text_color }};
    text-align: center;
    padding: 12px 20px;
    font-size: {{ block.settings.font_size }}px;
    line-height: 1.4;
  }

  .ai-announcement-bar-{{ ai_gen_id }}[hidden] {
    display: none;
  }

  .ai-announcement-bar__content-{{ ai_gen_id }} {
    margin: 0;
    padding: 0;
  }

  @media screen and (max-width: 749px) {
    .ai-announcement-bar-{{ ai_gen_id }} {
      font-size: {{ block.settings.font_size | times: 0.9 }}px;
      padding: 10px 16px;
    }
  }
{% endstyle %}

<div
  class="ai-announcement-bar-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
  {% unless block.settings.show_announcement %}hidden{% endunless %}
>
  <p class="ai-announcement-bar__content-{{ ai_gen_id }}">
    {{ block.settings.announcement_text }}
  </p>
</div>

{% schema %}
{
  "name": "Announcement bar",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_announcement",
      "label": "Show announcement bar",
      "default": true
    },
    {
      "type": "inline_richtext",
      "id": "announcement_text",
      "label": "Announcement text",
      "default": "Free shipping on all orders"
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#F5612A"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#FFFFFF"
    },
    {
      "type": "range",
      "id": "font_size",
      "label": "Font size",
      "min": 12,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 14
    }
  ],
  "presets": [
    {
      "name": "Announcement bar"
    }
  ]
}
{% endschema %}
