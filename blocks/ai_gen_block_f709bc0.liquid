{% doc %}
  @prompt
    Create a custom announcement bar section for a Shopify theme. The announcement bar should display the message "Free shipping on all orders" and be positioned at the very top of the page, inside the header. It should have customizable settings including: announcement text, background color, text color, and the ability to show/hide the bar. Style it to be clean and minimal, matching a simple and functional store design. Make it a standalone section that can be added to the theme header group.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-announcement-bar-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.background_color }};
    color: {{ block.settings.text_color }};
    padding: 10px 24px;
    line-height: 1.35;
  }
  .ai-announcement-bar-{{ ai_gen_id }}[hidden] { display: none; }

  .ai-announcement-bar__row-{{ ai_gen_id }} {
    margin: 0 auto;
    max-width: 1180px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
  }
  .ai-announcement-bar__primary-{{ ai_gen_id }} {
    margin: 0;
    font-size: {{ block.settings.font_size }}px;
    font-weight: 600;
    flex: 0 0 auto;
  }
  .ai-announcement-bar__secondary-{{ ai_gen_id }} {
    margin: 0;
    font-size: {{ block.settings.font_size | minus: 4 }}px;
    opacity: 0.94;
    text-align: right;
    flex: 1 1 auto;
    min-width: 0;
  }

  @media screen and (max-width: 749px) {
    .ai-announcement-bar-{{ ai_gen_id }} { padding: 8px 14px; }
    .ai-announcement-bar__row-{{ ai_gen_id }} {
      flex-direction: column;
      gap: 2px;
      text-align: center;
    }
    .ai-announcement-bar__primary-{{ ai_gen_id }} {
      font-size: {{ block.settings.font_size | times: 0.92 }}px;
    }
    .ai-announcement-bar__secondary-{{ ai_gen_id }} {
      font-size: {{ block.settings.font_size | minus: 5 }}px;
      text-align: center;
    }
  }
{% endstyle %}

<div
  class="ai-announcement-bar-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
  {% unless block.settings.show_announcement %}hidden{% endunless %}
>
  <div class="ai-announcement-bar__row-{{ ai_gen_id }}">
    <p class="ai-announcement-bar__primary-{{ ai_gen_id }}">{{ block.settings.announcement_text }}</p>
    {%- if block.settings.secondary_text != blank -%}
      <p class="ai-announcement-bar__secondary-{{ ai_gen_id }}">{{ block.settings.secondary_text }}</p>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Announcement bar",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_announcement",
      "label": "Show announcement bar",
      "default": true
    },
    {
      "type": "inline_richtext",
      "id": "announcement_text",
      "label": "Primary text (left, bold)",
      "default": "Free shipping on all orders"
    },
    {
      "type": "inline_richtext",
      "id": "secondary_text",
      "label": "Secondary text (right, smaller)",
      "default": "Tens of thousands of people fall each year while taking out their bins. Ready Eddie helps avoid unnecessary trips."
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#F5612A"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#FFFFFF"
    },
    {
      "type": "range",
      "id": "font_size",
      "label": "Font size",
      "min": 12,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 14
    }
  ],
  "presets": [
    {
      "name": "Announcement bar"
    }
  ]
}
{% endschema %}
