<!DOCTYPE html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{{ page_title }}{% unless page_title contains shop.name %} — {{ shop.name }}{% endunless %}</title>
  {% if page_description %}<meta name="description" content="{{ page_description | escape }}" />{% endif %}
  <meta name="theme-color" content="{{ settings.background_color | default: '#FAF8F2' }}" />

  {%- if settings.google_site_verification != blank -%}
    <meta name="google-site-verification" content="{{ settings.google_site_verification | escape }}" />
  {%- endif -%}
  {%- if settings.msvalidate_token != blank -%}
    <meta name="msvalidate.01" content="{{ settings.msvalidate_token | escape }}" />
  {%- endif -%}

  {% if settings.favicon %}
    <link rel="icon" type="image/png" sizes="32x32" href="{{ settings.favicon | image_url: width: 32 }}" />
    <link rel="apple-touch-icon" href="{{ settings.favicon | image_url: width: 180 }}" />
  {% else %}
    <link rel="icon" type="image/png" sizes="64x64" href="{{ 'WebsiteLogo-64.png' | asset_url }}" />
    <link rel="apple-touch-icon" href="{{ 'WebsiteLogo-128.png' | asset_url }}" />
  {% endif %}

  {%- comment -%}
    Only preconnect to gstatic (where the actual woff2 files live).
    Preconnecting to googleapis doesn't help — the CSS request is
    render-blocking either way, and extra preconnects warn in Lighthouse.
    Load fonts CSS non-blocking via preload→stylesheet swap so it
    can't hold up first paint; noscript fallback for no-JS visitors.
  {%- endcomment -%}
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  {%- assign fonts_url = 'https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,500;0,9..144,600;1,9..144,500&family=Instrument+Sans:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap' -%}
  <link rel="preload" as="style" href="{{ fonts_url }}" onload="this.onload=null;this.rel='stylesheet'" />
  <noscript><link rel="stylesheet" href="{{ fonts_url }}" /></noscript>

  {%- comment -%}
    Preload the homepage hero LCP image so the browser can start
    fetching it during HTML parse instead of waiting until the <img>
    tag is reached. Uses imagesrcset/imagesizes so the browser
    picks the same variant the <img> would have picked.
  {%- endcomment -%}
  {%- if template == 'index' and settings.lcp_product_handle != blank -%}
    {%- assign lcp_product = all_products[settings.lcp_product_handle] -%}
    {%- if lcp_product.featured_image -%}
      <link
        rel="preload"
        as="image"
        href="{{ lcp_product.featured_image | image_url: width: 720 }}"
        imagesrcset="{{ lcp_product.featured_image | image_url: width: 320 }} 320w, {{ lcp_product.featured_image | image_url: width: 420 }} 420w, {{ lcp_product.featured_image | image_url: width: 520 }} 520w, {{ lcp_product.featured_image | image_url: width: 720 }} 720w, {{ lcp_product.featured_image | image_url: width: 900 }} 900w, {{ lcp_product.featured_image | image_url: width: 1200 }} 1200w"
        imagesizes="(max-width: 480px) 84vw, (max-width: 820px) 70vw, 36vw"
        fetchpriority="high"
      />
    {%- endif -%}
  {%- endif -%}

  {{ 'theme.css' | asset_url | stylesheet_tag }}

  {{ content_for_header }}
</head>
<body>

  {% section 'header' %}

  <main>
    {{ content_for_layout }}
  </main>

  {% section 'footer' %}

  <script src="{{ 'theme.js' | asset_url }}" defer></script>
</body>
</html>
