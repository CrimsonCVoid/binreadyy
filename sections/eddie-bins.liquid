<section class="bins">
  <div class="bins-inner">
    {%- if section.settings.eyebrow != blank -%}
      <div class="eyebrow">{{ section.settings.eyebrow }}</div>
    {%- endif -%}
    {%- if section.settings.heading != blank -%}
      <h2 class="display">{{ section.settings.heading }}</h2>
    {%- endif -%}
    {%- if section.settings.lead != blank -%}
      <p class="lead">{{ section.settings.lead }}</p>
    {%- endif -%}

    <div class="bins-grid">
      {%- for block in section.blocks -%}
        {%- if block.type == 'bin' -%}
          {%- assign accent_class = '' -%}
          {%- if block.settings.tag_style == 'orange' -%}{%- assign accent_class = 'b' -%}{%- endif -%}
          <div class="bin {{ accent_class }}" {{ block.shopify_attributes }}>
            <div class="photo">
              {%- if block.settings.image != blank -%}
                <img src="{{ block.settings.image | image_url: width: 800 }}"
                     alt="{{ block.settings.image.alt | default: block.settings.title | escape }}"
                     loading="lazy" />
              {%- else -%}
                {%- assign fallback = block.settings.fallback_asset | default: 'RaisedBin.jpeg' -%}
                <img src="{{ fallback | asset_url }}"
                     alt="{{ block.settings.title | escape }}"
                     loading="lazy" />
              {%- endif -%}
            </div>
            <div class="body">
              {%- if block.settings.tag_label != blank -%}
                <span class="tag">{{ block.settings.tag_label }}</span>
              {%- endif -%}
              {%- if block.settings.title != blank -%}
                <h3>{{ block.settings.title }}</h3>
              {%- endif -%}
              {%- if block.settings.test != blank -%}
                <div class="test">{{ block.settings.test }}</div>
              {%- endif -%}
              {%- if block.settings.cuff_text != blank -%}
                <div class="pick">
                  <span class="cuff-swatch {{ block.settings.cuff_color }}"></span>
                  {{ block.settings.cuff_text }}
                </div>
              {%- endif -%}
            </div>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Eddie - Bin picker",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Pick the right cuff"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Match your bin."
    },
    {
      "type": "textarea",
      "id": "lead",
      "label": "Intro paragraph",
      "default": "Look at your bin from the side. The pack ships with the right cuff so you don't have to guess at the store."
    }
  ],
  "blocks": [
    {
      "type": "bin",
      "name": "Bin variant",
      "limit": 4,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Bin photo"
        },
        {
          "type": "text",
          "id": "fallback_asset",
          "label": "Fallback image filename (in /assets)",
          "info": "Used only if no image is uploaded above. e.g. RaisedBin.jpeg or LidLevel.jpeg",
          "default": "RaisedBin.jpeg"
        },
        {
          "type": "text",
          "id": "tag_label",
          "label": "Tag label (top corner)",
          "default": "BIN A"
        },
        {
          "type": "select",
          "id": "tag_style",
          "label": "Tag color",
          "options": [
            { "value": "dark", "label": "Dark (default)" },
            { "value": "orange", "label": "Orange" }
          ],
          "default": "dark"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Bin title",
          "default": "Lid sits higher than the handle"
        },
        {
          "type": "textarea",
          "id": "test",
          "label": "How to tell (italic quote)",
          "default": "Visible gap between the closed lid and the handle bar below it."
        },
        {
          "type": "text",
          "id": "cuff_text",
          "label": "Cuff recommendation text",
          "default": "Use the gray cuff"
        },
        {
          "type": "select",
          "id": "cuff_color",
          "label": "Cuff swatch color",
          "options": [
            { "value": "gray", "label": "Gray" },
            { "value": "black", "label": "Black" }
          ],
          "default": "gray"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Eddie - Bin picker",
      "blocks": [
        {
          "type": "bin",
          "settings": {
            "fallback_asset": "RaisedBin.jpeg",
            "tag_label": "BIN A",
            "tag_style": "dark",
            "title": "Lid sits higher than the handle",
            "test": "Visible gap between the closed lid and the handle bar below it.",
            "cuff_text": "Use the gray cuff",
            "cuff_color": "gray"
          }
        },
        {
          "type": "bin",
          "settings": {
            "fallback_asset": "LidLevel.jpeg",
            "tag_label": "BIN B",
            "tag_style": "orange",
            "title": "Lid sits level with the handle",
            "test": "Closed lid lines up flush with the top of the handle. No gap.",
            "cuff_text": "Use the black cuff",
            "cuff_color": "black"
          }
        }
      ]
    }
  ]
}
{% endschema %}
