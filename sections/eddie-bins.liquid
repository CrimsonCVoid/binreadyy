<section class="bins">
  <div class="bins-inner">
    {%- if section.settings.eyebrow != blank -%}
      <div class="eyebrow">{{ section.settings.eyebrow }}</div>
    {%- endif -%}
    {%- if section.settings.heading != blank -%}
      <h2 class="display">{{ section.settings.heading }}</h2>
    {%- endif -%}
    {%- if section.settings.lead != blank -%}
      <p class="lead">{{ section.settings.lead }}</p>
    {%- endif -%}

    <div class="bins-grid">

      {%- comment -%} ---------- BIN A ---------- {%- endcomment -%}
      {%- if section.settings.show_bin_a -%}
        {%- assign tag_class_a = '' -%}
        {%- if section.settings.tag_style_a == 'orange' -%}{%- assign tag_class_a = 'b' -%}{%- endif -%}
        <div class="bin {{ tag_class_a }}">
          <div class="photo">
            {%- if section.settings.image_a != blank -%}
              <img src="{{ section.settings.image_a | image_url: width: 800 }}"
                   alt="{{ section.settings.image_a.alt | default: section.settings.title_a | escape }}"
                   loading="lazy" width="500" height="300" />
            {%- else -%}
              <img src="{{ 'RaisedBin.jpeg' | asset_url }}"
                   alt="{{ section.settings.title_a | default: 'Bin A side profile' | escape }}"
                   loading="lazy" />
            {%- endif -%}
          </div>
          <div class="body">
            {%- if section.settings.tag_label_a != blank -%}
              <span class="tag">{{ section.settings.tag_label_a }}</span>
            {%- endif -%}
            {%- if section.settings.title_a != blank -%}
              <h3>{{ section.settings.title_a }}</h3>
            {%- endif -%}
            {%- if section.settings.test_a != blank -%}
              <div class="test">{{ section.settings.test_a }}</div>
            {%- endif -%}
            {%- if section.settings.cuff_text_a != blank -%}
              <div class="pick">
                <span class="cuff-swatch {{ section.settings.cuff_color_a }}"></span>
                {{ section.settings.cuff_text_a }}
              </div>
            {%- endif -%}
          </div>
        </div>
      {%- endif -%}

      {%- comment -%} ---------- BIN B ---------- {%- endcomment -%}
      {%- if section.settings.show_bin_b -%}
        {%- assign tag_class_b = '' -%}
        {%- if section.settings.tag_style_b == 'orange' -%}{%- assign tag_class_b = 'b' -%}{%- endif -%}
        <div class="bin {{ tag_class_b }}">
          <div class="photo">
            {%- if section.settings.image_b != blank -%}
              <img src="{{ section.settings.image_b | image_url: width: 800 }}"
                   alt="{{ section.settings.image_b.alt | default: section.settings.title_b | escape }}"
                   loading="lazy" width="500" height="300" />
            {%- else -%}
              <img src="{{ 'LidLevel.jpeg' | asset_url }}"
                   alt="{{ section.settings.title_b | default: 'Bin B side profile' | escape }}"
                   loading="lazy" />
            {%- endif -%}
          </div>
          <div class="body">
            {%- if section.settings.tag_label_b != blank -%}
              <span class="tag">{{ section.settings.tag_label_b }}</span>
            {%- endif -%}
            {%- if section.settings.title_b != blank -%}
              <h3>{{ section.settings.title_b }}</h3>
            {%- endif -%}
            {%- if section.settings.test_b != blank -%}
              <div class="test">{{ section.settings.test_b }}</div>
            {%- endif -%}
            {%- if section.settings.cuff_text_b != blank -%}
              <div class="pick">
                <span class="cuff-swatch {{ section.settings.cuff_color_b }}"></span>
                {{ section.settings.cuff_text_b }}
              </div>
            {%- endif -%}
          </div>
        </div>
      {%- endif -%}

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Eddie - Bin picker",
  "settings": [
    {
      "type": "header",
      "content": "Section heading"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Pick the right cuff"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Match your bin."
    },
    {
      "type": "textarea",
      "id": "lead",
      "label": "Intro paragraph",
      "default": "Look at your bin from the side. The pack ships with the right cuff so you don't have to guess at the store."
    },

    {
      "type": "header",
      "content": "Bin A (left card)"
    },
    {
      "type": "checkbox",
      "id": "show_bin_a",
      "label": "Show this bin",
      "default": true
    },
    {
      "type": "image_picker",
      "id": "image_a",
      "label": "Bin A photo",
      "info": "If empty, falls back to RaisedBin.jpeg in /assets."
    },
    {
      "type": "text",
      "id": "tag_label_a",
      "label": "Tag label",
      "default": "BIN A"
    },
    {
      "type": "select",
      "id": "tag_style_a",
      "label": "Tag color",
      "options": [
        { "value": "dark", "label": "Dark" },
        { "value": "orange", "label": "Orange" }
      ],
      "default": "dark"
    },
    {
      "type": "text",
      "id": "title_a",
      "label": "Title",
      "default": "Lid sits higher than the handle"
    },
    {
      "type": "textarea",
      "id": "test_a",
      "label": "How to tell (italic quote)",
      "default": "Visible gap between the closed lid and the handle bar below it."
    },
    {
      "type": "text",
      "id": "cuff_text_a",
      "label": "Cuff recommendation text",
      "default": "Use the gray cuff"
    },
    {
      "type": "select",
      "id": "cuff_color_a",
      "label": "Cuff swatch color",
      "options": [
        { "value": "gray", "label": "Gray" },
        { "value": "black", "label": "Black" }
      ],
      "default": "gray"
    },

    {
      "type": "header",
      "content": "Bin B (right card)"
    },
    {
      "type": "checkbox",
      "id": "show_bin_b",
      "label": "Show this bin",
      "default": true
    },
    {
      "type": "image_picker",
      "id": "image_b",
      "label": "Bin B photo",
      "info": "If empty, falls back to LidLevel.jpeg in /assets."
    },
    {
      "type": "text",
      "id": "tag_label_b",
      "label": "Tag label",
      "default": "BIN B"
    },
    {
      "type": "select",
      "id": "tag_style_b",
      "label": "Tag color",
      "options": [
        { "value": "dark", "label": "Dark" },
        { "value": "orange", "label": "Orange" }
      ],
      "default": "orange"
    },
    {
      "type": "text",
      "id": "title_b",
      "label": "Title",
      "default": "Lid sits level with the handle"
    },
    {
      "type": "textarea",
      "id": "test_b",
      "label": "How to tell (italic quote)",
      "default": "Closed lid lines up flush with the top of the handle. No gap."
    },
    {
      "type": "text",
      "id": "cuff_text_b",
      "label": "Cuff recommendation text",
      "default": "Use the black cuff"
    },
    {
      "type": "select",
      "id": "cuff_color_b",
      "label": "Cuff swatch color",
      "options": [
        { "value": "gray", "label": "Gray" },
        { "value": "black", "label": "Black" }
      ],
      "default": "black"
    }
  ],
  "presets": [
    {
      "name": "Eddie - Bin picker"
    }
  ]
}
{% endschema %}
