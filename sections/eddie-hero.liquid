<section class="hero">
  <div class="wrap">
    {%- if section.settings.eyebrow != blank -%}
      <div class="eyebrow">{{ section.settings.eyebrow }}</div>
    {%- endif -%}

    <h1 class="display">
      {{ section.settings.heading_part_1 }}
      {%- if section.settings.heading_accent != blank %} <span class="accent">{{ section.settings.heading_accent }}</span>{% endif -%}
      {%- if section.settings.heading_part_2 != blank %} {{ section.settings.heading_part_2 }}{% endif -%}
      {%- if section.settings.heading_italic != blank %} <span class="it">{{ section.settings.heading_italic }}</span>{% endif -%}
    </h1>

    {%- if section.settings.body != blank -%}
      <p>{{ section.settings.body }}</p>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Eddie · Hero",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text (small label above headline)",
      "default": "You scanned the box. Hi."
    },
    {
      "type": "header",
      "content": "Headline (assembled from four pieces)"
    },
    {
      "type": "paragraph",
      "content": "The headline reads: [Part 1] [Accent in orange] [Part 2] [Italic word]. Leave any piece blank to skip it."
    },
    {
      "type": "text",
      "id": "heading_part_1",
      "label": "Part 1",
      "default": "It's a"
    },
    {
      "type": "text",
      "id": "heading_accent",
      "label": "Orange accent word",
      "default": "trash-day"
    },
    {
      "type": "text",
      "id": "heading_part_2",
      "label": "Part 2",
      "default": "signal."
    },
    {
      "type": "text",
      "id": "heading_italic",
      "label": "Italic serif word (optional, replaces Part 2 if used)",
      "default": "",
      "info": "Use this for a stylized italic word like 'signal.' If you fill this in, you may want to leave Part 2 blank."
    },
    {
      "type": "header",
      "content": "Body copy"
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "Description paragraph",
      "default": "Eddie clips onto the hinge of your bin. You flip him up before pickup; the truck flips him flat when it empties the bin. A glance from the porch tells you which is which."
    }
  ],
  "presets": [
    {
      "name": "Eddie · Hero"
    }
  ]
}
{% endschema %}
