<section class="hero">
  <div class="wrap">
    {%- if section.settings.eyebrow != blank -%}
      <div class="eyebrow">{{ section.settings.eyebrow }}</div>
    {%- endif -%}

    <h1 class="display">
      {{ section.settings.heading_part_1 }}
      {%- if section.settings.heading_accent != blank %} <span class="accent">{{ section.settings.heading_accent }}</span>{% endif -%}
      {%- if section.settings.heading_part_2 != blank %} {{ section.settings.heading_part_2 }}{% endif -%}
      {%- if section.settings.heading_italic != blank %} <span class="it">{{ section.settings.heading_italic }}</span>{% endif -%}
    </h1>

    {%- if section.settings.body != blank -%}
      <p>{{ section.settings.body }}</p>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Eddie - Hero",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "You scanned the box. Hi."
    },
    {
      "type": "header",
      "content": "Headline"
    },
    {
      "type": "text",
      "id": "heading_part_1",
      "label": "Headline part 1",
      "default": "It's a"
    },
    {
      "type": "text",
      "id": "heading_accent",
      "label": "Headline accent (orange word)",
      "default": "trash-day"
    },
    {
      "type": "text",
      "id": "heading_part_2",
      "label": "Headline part 2",
      "default": "signal."
    },
    {
      "type": "text",
      "id": "heading_italic",
      "label": "Headline italic word (optional)",
      "info": "Stylized italic word. If used, you may want to leave headline part 2 blank."
    },
    {
      "type": "header",
      "content": "Body copy"
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "Description paragraph",
      "default": "Eddie clips onto the hinge of your bin. You flip him up before pickup; the truck flips him flat when it empties the bin. A glance from the porch tells you which is which."
    }
  ],
  "presets": [
    {
      "name": "Eddie - Hero"
    }
  ]
}
{% endschema %}
