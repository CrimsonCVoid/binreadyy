<section class="steps">
  <div class="wrap">
    {%- if section.settings.eyebrow != blank -%}
      <div class="eyebrow" style="margin-bottom: 14px;">{{ section.settings.eyebrow }}</div>
    {%- endif -%}

    <h2 class="display">
      {{ section.settings.heading_part_1 }}
      {%- if section.settings.heading_italic != blank %} <span class="serif">{{ section.settings.heading_italic }}</span>{% endif -%}
    </h2>

    {%- for i in (1..6) -%}
      {%- assign num_key   = 'step_' | append: i | append: '_number' -%}
      {%- assign title_key = 'step_' | append: i | append: '_title' -%}
      {%- assign desc_key  = 'step_' | append: i | append: '_desc' -%}
      {%- assign step_title = section.settings[title_key] -%}
      {%- assign step_desc  = section.settings[desc_key] -%}
      {%- assign step_num   = section.settings[num_key] -%}
      {%- if step_title != blank or step_desc != blank -%}
        <div class="step">
          <div class="step-num">{{ step_num | default: i | prepend: '0' | slice: -2, 2 }}</div>
          <div>
            {%- if step_title != blank -%}<h3>{{ step_title }}</h3>{%- endif -%}
            {%- if step_desc  != blank -%}<p>{{ step_desc }}</p>{%- endif -%}
          </div>
        </div>
      {%- endif -%}
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "Eddie - Steps",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "The mechanism"
    },
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "text",
      "id": "heading_part_1",
      "label": "Main heading",
      "default": "No batteries."
    },
    {
      "type": "text",
      "id": "heading_italic",
      "label": "Italic serif phrase (optional)",
      "default": "No app."
    },

    {
      "type": "header",
      "content": "Step 1"
    },
    {
      "type": "text",
      "id": "step_1_number",
      "label": "Number",
      "default": "01"
    },
    {
      "type": "text",
      "id": "step_1_title",
      "label": "Title",
      "default": "Eddie up. Bin to the curb."
    },
    {
      "type": "textarea",
      "id": "step_1_desc",
      "label": "Description",
      "default": "Flip Ready Eddie up before you wheel the bin out. The orange figure with his arm in the air is your \"still full\" signal - visible from 60 feet, hard to miss."
    },

    {
      "type": "header",
      "content": "Step 2"
    },
    {
      "type": "text",
      "id": "step_2_number",
      "label": "Number",
      "default": "02"
    },
    {
      "type": "text",
      "id": "step_2_title",
      "label": "Title",
      "default": "Truck flips the bin"
    },
    {
      "type": "textarea",
      "id": "step_2_desc",
      "label": "Description",
      "default": "The lid swings past vertical during the dump. Eddie rotates around his cuff and lands flat on top of the lid as it falls back closed."
    },

    {
      "type": "header",
      "content": "Step 3"
    },
    {
      "type": "text",
      "id": "step_3_number",
      "label": "Number",
      "default": "03"
    },
    {
      "type": "text",
      "id": "step_3_title",
      "label": "Title",
      "default": "Eddie's down. It's done."
    },
    {
      "type": "textarea",
      "id": "step_3_desc",
      "label": "Description",
      "default": "Glance at the curb - no more orange arm in the air means the truck has come and gone. Push Eddie back up with one finger before next collection day. Repeat forever."
    },

    {
      "type": "header",
      "content": "Step 4 (optional)"
    },
    {
      "type": "text",
      "id": "step_4_number",
      "label": "Number"
    },
    {
      "type": "text",
      "id": "step_4_title",
      "label": "Title"
    },
    {
      "type": "textarea",
      "id": "step_4_desc",
      "label": "Description"
    },

    {
      "type": "header",
      "content": "Step 5 (optional)"
    },
    {
      "type": "text",
      "id": "step_5_number",
      "label": "Number"
    },
    {
      "type": "text",
      "id": "step_5_title",
      "label": "Title"
    },
    {
      "type": "textarea",
      "id": "step_5_desc",
      "label": "Description"
    },

    {
      "type": "header",
      "content": "Step 6 (optional)"
    },
    {
      "type": "text",
      "id": "step_6_number",
      "label": "Number"
    },
    {
      "type": "text",
      "id": "step_6_title",
      "label": "Title"
    },
    {
      "type": "textarea",
      "id": "step_6_desc",
      "label": "Description"
    }
  ],
  "presets": [
    {
      "name": "Eddie - Steps"
    }
  ]
}
{% endschema %}
