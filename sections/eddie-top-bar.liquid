<header class="top">
  <div class="top-inner">
    {%- if section.settings.show_back -%}
      <a href="{{ section.settings.back_url | default: '/' }}" class="top-back" aria-label="{{ section.settings.back_aria | default: 'Return to front page' | escape }}">
        <span class="top-back-arrow" aria-hidden="true">&larr;</span>
        <span class="top-back-label">{{ section.settings.back_label | default: 'Front page' }}</span>
      </a>
    {%- else -%}
      <span></span>
    {%- endif -%}

    <nav class="top-nav" aria-label="{{ section.settings.nav_aria | default: 'Site sections' | escape }}">
      {%- if section.settings.link_1_label != blank and section.settings.link_1_url != blank -%}
        <a href="{{ section.settings.link_1_url }}">{{ section.settings.link_1_label }}</a>
      {%- endif -%}
      {%- if section.settings.link_2_label != blank and section.settings.link_2_url != blank -%}
        <a href="{{ section.settings.link_2_url }}">{{ section.settings.link_2_label }}</a>
      {%- endif -%}
      {%- if section.settings.link_3_label != blank and section.settings.link_3_url != blank -%}
        <a href="{{ section.settings.link_3_url }}">{{ section.settings.link_3_label }}</a>
      {%- endif -%}
      {%- if section.settings.link_4_label != blank and section.settings.link_4_url != blank -%}
        <a href="{{ section.settings.link_4_url }}">{{ section.settings.link_4_label }}</a>
      {%- endif -%}
    </nav>

    {%- if section.settings.show_buy -%}
      <a href="{{ section.settings.buy_url | default: '/#buy' }}" class="top-buy">{{ section.settings.buy_label | default: 'Buy' }}</a>
    {%- else -%}
      <span></span>
    {%- endif -%}
  </div>
</header>

{% schema %}
{
  "name": "Eddie - Top bar",
  "settings": [
    {
      "type": "header",
      "content": "Back link (left side)"
    },
    {
      "type": "checkbox",
      "id": "show_back",
      "label": "Show back link",
      "default": true
    },
    {
      "type": "text",
      "id": "back_label",
      "label": "Back link text",
      "default": "Front page"
    },
    {
      "type": "text",
      "id": "back_url",
      "label": "Back link URL",
      "default": "/"
    },
    {
      "type": "text",
      "id": "back_aria",
      "label": "Back link screen-reader description",
      "default": "Return to front page"
    },

    {
      "type": "header",
      "content": "Navigation links (center)"
    },
    {
      "type": "text",
      "id": "nav_aria",
      "label": "Navigation screen-reader label",
      "default": "Site sections"
    },
    {
      "type": "text",
      "id": "link_1_label",
      "label": "Link 1 text",
      "default": "Reviews"
    },
    {
      "type": "text",
      "id": "link_1_url",
      "label": "Link 1 URL",
      "default": "/#reviews"
    },
    {
      "type": "text",
      "id": "link_2_label",
      "label": "Link 2 text",
      "default": "FAQ"
    },
    {
      "type": "text",
      "id": "link_2_url",
      "label": "Link 2 URL",
      "default": "/#faq"
    },
    {
      "type": "text",
      "id": "link_3_label",
      "label": "Link 3 text",
      "default": "Contact us"
    },
    {
      "type": "text",
      "id": "link_3_url",
      "label": "Link 3 URL",
      "default": "/#help"
    },
    {
      "type": "text",
      "id": "link_4_label",
      "label": "Link 4 text (optional)"
    },
    {
      "type": "text",
      "id": "link_4_url",
      "label": "Link 4 URL (optional)"
    },

    {
      "type": "header",
      "content": "Buy button (right side)"
    },
    {
      "type": "checkbox",
      "id": "show_buy",
      "label": "Show buy button",
      "default": true
    },
    {
      "type": "text",
      "id": "buy_label",
      "label": "Buy button text",
      "default": "Buy"
    },
    {
      "type": "text",
      "id": "buy_url",
      "label": "Buy button URL",
      "default": "/#buy",
      "info": "Use /#buy to scroll to the buy section on the homepage, or /products/ready-eddie."
    }
  ],
  "presets": [
    {
      "name": "Eddie - Top bar"
    }
  ]
}
{% endschema %}
