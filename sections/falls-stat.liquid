<section class="falls-stat" aria-label="Why this matters">
  <div class="container falls-stat-row">
    <span class="falls-stat-icon" aria-hidden="true">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none">
        <path d="M12 7V3m0 0L9 5m3-2 3 2M5 13a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v3a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2v-3Zm3 8h8" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </span>
    <p class="falls-stat-text">
      <strong>{{ section.settings.stat_lead | default: 'Tens of thousands of people fall each year' }}</strong>
      <span>{{ section.settings.stat_body | default: 'while taking out or bringing in their bins. Ready Eddie helps avoid unnecessary trips.' }}</span>
    </p>
  </div>
</section>

{% schema %}
{
  "name": "Falls stat callout",
  "settings": [
    { "type": "text", "id": "stat_lead", "label": "Stat (bold lead)", "default": "Tens of thousands of people fall each year" },
    { "type": "textarea", "id": "stat_body", "label": "Supporting text", "default": "while taking out or bringing in their bins. Ready Eddie helps avoid unnecessary trips." }
  ],
  "presets": [
    { "name": "Falls stat callout" }
  ]
}
{% endschema %}
