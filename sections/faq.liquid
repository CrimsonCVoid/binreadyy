<section class="faq" id="faq" aria-labelledby="faq-title">
  <div class="container">
    <div class="faq-head">
      <h2 id="faq-title" class="reveal">{{ section.settings.heading }}</h2>
      {%- if section.settings.subheading != blank -%}
        <p class="reveal reveal-d1">{{ section.settings.subheading }}</p>
      {%- endif -%}
    </div>
    <div class="faq-list reveal reveal-d2">
      {%- for block in section.blocks -%}
        <details class="faq-item" {{ block.shopify_attributes }}>
          <summary>
            {{ block.settings.question }}
            <span class="faq-icon" aria-hidden="true"></span>
          </summary>
          <div class="faq-a">{{ block.settings.answer }}</div>
        </details>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "FAQ",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Questions?"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "The short ones first. Email us if you want the long ones."
    }
  ],
  "blocks": [
    {
      "type": "faq",
      "name": "Question",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question"
        },
        {
          "type": "textarea",
          "id": "answer",
          "label": "Answer"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "FAQ",
      "blocks": [
        { "type": "faq", "settings": { "question": "Will it fit my bin?", "answer": "Yes. Eddie clips onto the molded pull-handle found on virtually every standard curbside trash and recycling bin in the U.S." } },
        { "type": "faq", "settings": { "question": "What if it's windy or rainy?", "answer": "Weighted to stay put in normal weather. Built to handle rain, snow, sun, and heat year-round. No electronics to fry." } },
        { "type": "faq", "settings": { "question": "Does the garbage truck have to do anything different?", "answer": "Nope. The natural motion of your bin being lifted and emptied flips Ready Eddie down on its own. The driver might not even notice, but Ready Eddie can also tell the driver that your bin needs emptying, reducing the likelihood that they miss your bin." } },
        { "type": "faq", "settings": { "question": "What if I don't love it?", "answer": "Send it back within 30 days for a full refund. No questions, no restocking fee, no hoops." } }
      ]
    }
  ]
}
{% endschema %}
