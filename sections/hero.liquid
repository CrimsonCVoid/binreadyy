{%- assign product = all_products[section.settings.product] | default: product -%}

{%- comment -%}
  Demo video. A bundled clip (CoverCenterVideo.mp4) ships as the default so the
  play button is always live. The theme editor can override it: an uploaded file
  or a YouTube/Vimeo link both take precedence over the bundled clip.
{%- endcomment -%}
{%- assign has_video = true -%}

<section class="hero" aria-labelledby="hero-title">
  <div class="container">
    <div class="hero-grid">

      <!-- LEFT: Product stage -->
      <div class="product-stage">
        {%- if section.settings.show_ship_badge -%}
          {%- assign ship_text = section.settings.ship_badge_text | default: settings.free_shipping_note | default: 'Free shipping on all orders' -%}
          <span class="ship-badge">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
              <path d="M3 7.4l2.6 2.6L11 4.6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            {{ ship_text }}
          </span>
        {%- endif -%}
        <div class="product-frame">
          {%- if product.featured_image -%}
            <img
              class="product-img"
              src="{{ product.featured_image | image_url: width: 720 }}"
              srcset="
                {{ product.featured_image | image_url: width: 320 }} 320w,
                {{ product.featured_image | image_url: width: 420 }} 420w,
                {{ product.featured_image | image_url: width: 520 }} 520w,
                {{ product.featured_image | image_url: width: 720 }} 720w,
                {{ product.featured_image | image_url: width: 900 }} 900w,
                {{ product.featured_image | image_url: width: 1200 }} 1200w
              "
              sizes="(max-width: 480px) 84vw, (max-width: 820px) 70vw, 36vw"
              alt="{{ product.featured_image.alt | default: product.title | default: 'Ready Eddie clipped on a curbside bin' }}"
              width="{{ product.featured_image.width }}"
              height="{{ product.featured_image.height }}"
              loading="eager"
              fetchpriority="high"
            />
          {%- else -%}
            <img
              class="product-img"
              src="{{ 'OrangeEddy-1200.jpg' | asset_url }}"
              srcset="{{ 'OrangeEddy-640.jpg' | asset_url }} 640w, {{ 'OrangeEddy-1200.jpg' | asset_url }} 1200w"
              sizes="(max-width: 820px) 84vw, 44vw"
              alt="{{ section.settings.heading | default: 'Ready Eddie' }}"
              width="1024"
              height="1536"
              loading="eager"
              fetchpriority="high"
            />
          {%- endif -%}
          {%- if has_video -%}
            <button type="button" class="video-trigger" aria-haspopup="dialog" aria-controls="hero-video-modal">
              <span class="video-trigger-ring" aria-hidden="true">
                <svg width="22" height="22" viewBox="0 0 22 22" fill="none">
                  <path d="M8 6.5l8 4.5-8 4.5V6.5z" fill="currentColor"/>
                </svg>
              </span>
              <span class="video-trigger-label">{{ section.settings.video_label | default: 'See how it works' }}</span>
            </button>
          {%- endif -%}
        </div>
      </div>

      <!-- RIGHT: Buy panel -->
      <div class="buy-panel">
        {%- if section.settings.kicker != blank -%}
          <span class="kicker">{{ section.settings.kicker }}</span>
        {%- endif -%}

        <h1 id="hero-title">{{ section.settings.heading }}</h1>

        {%- if section.settings.lede != blank -%}
          <p class="lede">{{ section.settings.lede }}</p>
        {%- endif -%}

        {%- if section.settings.gift_note != blank -%}
          <p class="hero-gift">{{ section.settings.gift_note }}</p>
        {%- endif -%}

        {%- if section.settings.safety_note != blank -%}
          <aside class="hero-note" aria-label="Why this matters">
            <p>{{ section.settings.safety_note }}</p>
            {%- if section.settings.safety_note_2 != blank -%}
              <p class="hero-note-q">{{ section.settings.safety_note_2 }}</p>
            {%- endif -%}
          </aside>
        {%- endif -%}

        {% render 'buy-button', product: product %}
      </div>

    </div>
  </div>
</section>

{%- if has_video -%}
  <div class="video-modal" id="hero-video-modal" role="dialog" aria-modal="true" aria-label="{{ section.settings.video_label | default: 'See how it works' | escape }}" hidden>
    <div class="video-modal-overlay" data-video-close></div>
    <div class="video-modal-frame" role="document">
      <button type="button" class="video-modal-close" data-video-close aria-label="Close video">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
          <path d="M5 5l10 10M15 5L5 15" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
        </svg>
      </button>
      <div class="video-modal-media">
        {%- if section.settings.video_file != blank -%}
          {{ section.settings.video_file | video_tag: image_size: '1100x', controls: true, preload: 'none', class: 'video-modal-el' }}
        {%- elsif section.settings.demo_video.type == 'youtube' -%}
          <iframe class="video-modal-el" data-src="https://www.youtube.com/embed/{{ section.settings.demo_video.id }}?autoplay=1&rel=0&modestbranding=1" title="{{ section.settings.video_label | default: 'See how it works' | escape }}" allow="autoplay; encrypted-media; picture-in-picture; fullscreen" allowfullscreen loading="lazy"></iframe>
        {%- elsif section.settings.demo_video.type == 'vimeo' -%}
          <iframe class="video-modal-el" data-src="https://player.vimeo.com/video/{{ section.settings.demo_video.id }}?autoplay=1" title="{{ section.settings.video_label | default: 'See how it works' | escape }}" allow="autoplay; fullscreen; picture-in-picture" allowfullscreen loading="lazy"></iframe>
        {%- else -%}
          <video class="video-modal-el" controls playsinline loop preload="none" poster="{% if product.featured_image %}{{ product.featured_image | image_url: width: 1080 }}{% else %}{{ 'OrangeEddy-1200.jpg' | asset_url }}{% endif %}">
            <source src="{{ 'CoverCenterVideo.mp4' | asset_url }}" type="video/mp4" />
          </video>
        {%- endif -%}
      </div>
    </div>
  </div>
{%- endif -%}

{% render 'mobile-shop-bar', product: product %}

{% schema %}
{
  "name": "Hero",
  "settings": [
    {
      "type": "product",
      "id": "product",
      "label": "Product"
    },
    {
      "type": "header",
      "content": "Demo video (how it works)"
    },
    {
      "type": "paragraph",
      "content": "Add a short demo and a play button appears over the product image, opening it in a pop-up. Upload a file OR paste a YouTube/Vimeo link. If both are set, the uploaded file wins."
    },
    {
      "type": "video",
      "id": "video_file",
      "label": "Upload a video"
    },
    {
      "type": "video_url",
      "id": "demo_video",
      "label": "…or paste a YouTube / Vimeo link",
      "accept": ["youtube", "vimeo"]
    },
    {
      "type": "text",
      "id": "video_label",
      "label": "Play button / pop-up label",
      "default": "See how it works"
    },
    {
      "type": "text",
      "id": "kicker",
      "label": "Kicker (small text above heading)",
      "default": "A small, simple gadget. a big convenience."
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Know when your bin has been emptied."
    },
    {
      "type": "textarea",
      "id": "lede",
      "label": "Description",
      "default": "Flip Ready Eddie up on collection day. When the truck empties your bin, gravity flips Eddie down. One glance from the house — done. No apps, no batteries, no wondering, no unnecessary trips."
    },
    {
      "type": "text",
      "id": "gift_note",
      "label": "Gift callout (dashed divider above it)",
      "info": "Short line set off from the description, e.g. a seasonal gift angle.",
      "default": "Makes a great Father's Day gift for Dad!"
    },
    {
      "type": "header",
      "content": "Safety note (under description)"
    },
    {
      "type": "textarea",
      "id": "safety_note",
      "label": "Italic editorial line under the description",
      "default": "Tens of thousands of people fall each year while taking out their bins. Ready Eddie helps avoid unnecessary trips."
    },
    {
      "type": "textarea",
      "id": "safety_note_2",
      "label": "Second italic line (optional)",
      "info": "Stacks under the first line inside the same accent-bordered note."
    },
    {
      "type": "header",
      "content": "Free-shipping badge (above product image)"
    },
    {
      "type": "checkbox",
      "id": "show_ship_badge",
      "label": "Show free-shipping badge",
      "default": true
    },
    {
      "type": "text",
      "id": "ship_badge_text",
      "label": "Badge text (defaults to theme setting)",
      "default": "Free shipping on all orders"
    }
  ],
  "presets": [
    {
      "name": "Hero"
    }
  ]
}
{% endschema %}
