<section class="how" id="how" aria-labelledby="how-title">
  <div class="container">
    <div class="how-head">
      <h2 id="how-title" class="reveal">{{ section.settings.heading }}</h2>
      {%- if section.settings.subheading != blank -%}
        <p class="reveal reveal-d1">{{ section.settings.subheading }}</p>
      {%- endif -%}
    </div>
    <div class="how-grid">
      <div class="scene-wrap reveal" id="scene-wrap">
        <div class="scene-label" aria-hidden="true">
          <span class="label-full">Bin is full</span>
          <span class="label-empty">Bin is empty</span>
        </div>
        <div class="scene-frame">
          {% render 'svg-animation' %}
        </div>
      </div>

      <div class="how-right">
        <ol class="how-steps">
          {%- if section.settings.show_install_rules -%}
            <li class="reveal how-step--cuff">
              <h3>{{ section.settings.install_rules_label | default: 'Pick your cuff' }}</h3>
              <div class="cuff-pick-grid">
                <div class="cuff-pick">
                  <img
                    class="cuff-pick-thumb"
                    src="{{ 'RaisedBin.jpeg' | asset_url }}"
                    width="120" height="120"
                    alt="Bin profile with lid sitting above the handle"
                    loading="lazy"
                    decoding="async"
                  />
                  <div class="cuff-pick-body">
                    <span class="cuff-pick-tag">
                      <span class="cuff-pick-swatch cuff-pick-swatch--gray" aria-hidden="true"></span>
                      Gray cuff
                    </span>
                    <p>{{ section.settings.install_rule_gray }}</p>
                  </div>
                </div>
                <div class="cuff-pick">
                  <img
                    class="cuff-pick-thumb"
                    src="{{ 'LidLevel.jpeg' | asset_url }}"
                    width="120" height="120"
                    alt="Bin profile with lid level with the handle"
                    loading="lazy"
                    decoding="async"
                  />
                  <div class="cuff-pick-body">
                    <span class="cuff-pick-tag">
                      <span class="cuff-pick-swatch cuff-pick-swatch--black" aria-hidden="true"></span>
                      Black cuff
                    </span>
                    <p>{{ section.settings.install_rule_black }}</p>
                  </div>
                </div>
              </div>
            </li>
          {%- endif -%}

          {%- for block in section.blocks -%}
            {%- assign delay_idx = forloop.index -%}
            {%- if section.settings.show_install_rules -%}{%- assign delay_idx = forloop.index | plus: 1 -%}{%- endif -%}
            <li class="reveal{% if delay_idx > 1 %} reveal-d{{ delay_idx | minus: 1 | at_most: 4 }}{% endif %}" {{ block.shopify_attributes }}>
              <h3>{{ block.settings.title }}</h3>
              <p>{{ block.settings.description }}</p>
            </li>
          {%- endfor -%}
        </ol>

        {%- if section.settings.more_label != blank and section.settings.more_url != blank -%}
          <a href="{{ section.settings.more_url }}" class="how-more reveal reveal-d3">
            <span class="how-more-text">{{ section.settings.more_label }}</span>
            {%- if section.settings.more_sublabel != blank -%}
              <span class="how-more-sub">{{ section.settings.more_sublabel }}</span>
            {%- endif -%}
            <span class="how-more-arrow" aria-hidden="true">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                <path d="M3 8h10m-3.5-3.5L13 8l-3.5 3.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
          </a>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "How it works",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Three steps. No electronics."
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Mechanical. Boring. Exactly what you want it to be."
    },
    {
      "type": "header",
      "content": "Install rules (above the heading)"
    },
    {
      "type": "checkbox",
      "id": "show_install_rules",
      "label": "Show cuff-pick rules at the top",
      "default": true
    },
    {
      "type": "text",
      "id": "install_rules_label",
      "label": "Eyebrow label",
      "default": "Pick your cuff"
    },
    {
      "type": "textarea",
      "id": "install_rule_gray",
      "label": "Gray-cuff rule",
      "default": "If the top of your bin lid is above your bin handle, put the GRAY cuff on your handle, and wrap Ready Eddie around it."
    },
    {
      "type": "textarea",
      "id": "install_rule_black",
      "label": "Black-cuff rule",
      "default": "If the top of your bin lid is level with the top of your bin handle, use the BLACK cuff."
    },
    {
      "type": "header",
      "content": "Deeper-dive link"
    },
    {
      "type": "text",
      "id": "more_label",
      "label": "Link label",
      "default": "See the full breakdown"
    },
    {
      "type": "text",
      "id": "more_sublabel",
      "label": "Link sublabel (optional)",
      "default": "Photos, mechanism, install — 60 seconds"
    },
    {
      "type": "text",
      "id": "more_url",
      "label": "Link URL (e.g. /pages/how-ready-eddie-works)",
      "default": "/pages/how-ready-eddie-works",
      "info": "Use a relative path like /pages/your-page or a full URL."
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Step title",
          "default": "Flip Ready Eddie up"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Step description",
          "default": "On collection day, flip Ready Eddie upright on your bin handle. Done."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "How it works",
      "blocks": [
        { "type": "step", "settings": { "title": "Flip Ready Eddie up", "description": "On collection day, flip Ready Eddie upright on your bin handle. Done." } },
        { "type": "step", "settings": { "title": "The truck empties the bin", "description": "Gravity does its thing and flips Eddie down." } },
        { "type": "step", "settings": { "title": "Glance from the house", "description": "If Eddie is down, it's done. That's it." } }
      ]
    }
  ]
}
{% endschema %}
