<section class="safety-banner" aria-label="Safety">
  <div class="container safety-banner-row">
    <span class="safety-banner-icon" aria-hidden="true">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
        <path d="M12 9v4m0 4h.01M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0Z" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </span>
    <p class="safety-banner-text">
      <strong>{{ section.settings.lead | default: 'Tens of thousands of people fall each year' }}</strong>
      <span>{{ section.settings.body | default: 'while taking out their bins. Ready Eddie helps avoid unnecessary trips.' }}</span>
    </p>
  </div>
</section>

{% schema %}
{
  "name": "Safety banner",
  "settings": [
    { "type": "text", "id": "lead", "label": "Lead (bold, accent color)", "default": "Tens of thousands of people fall each year" },
    { "type": "textarea", "id": "body", "label": "Body", "default": "while taking out their bins. Ready Eddie helps avoid unnecessary trips." }
  ],
  "presets": [
    { "name": "Safety banner" }
  ]
}
{% endschema %}
