{%- liquid
  assign featured_block = nil
  for block in section.blocks
    if block.settings.featured
      assign featured_block = block
      break
    endif
  endfor

  assign trust_line = section.settings.trust_line
  assign rating = section.settings.rating | default: 4.9
-%}

<section class="testimonials" id="reviews" aria-labelledby="testimonials-title">
  <div class="container">
    <header class="testimonials-head">
      {%- if section.settings.kicker != blank -%}
        <span class="kicker reveal">{{ section.settings.kicker }}</span>
      {%- endif -%}
      <h2 id="testimonials-title" class="reveal reveal-d1">{{ section.settings.heading }}</h2>
      {%- if section.settings.subheading != blank -%}
        <p class="testimonials-sub reveal reveal-d2">{{ section.settings.subheading }}</p>
      {%- endif -%}
      {%- if trust_line != blank -%}
        <p class="testimonials-trust reveal reveal-d2" aria-label="Customer rating">
          <span class="stars" aria-hidden="true">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="currentColor"><path d="M7 1l1.85 3.74 4.15.6-3 2.92.71 4.13L7 10.45 3.29 12.4 4 8.27 1 5.34l4.15-.6L7 1z"/></svg>
            <svg width="14" height="14" viewBox="0 0 14 14" fill="currentColor"><path d="M7 1l1.85 3.74 4.15.6-3 2.92.71 4.13L7 10.45 3.29 12.4 4 8.27 1 5.34l4.15-.6L7 1z"/></svg>
            <svg width="14" height="14" viewBox="0 0 14 14" fill="currentColor"><path d="M7 1l1.85 3.74 4.15.6-3 2.92.71 4.13L7 10.45 3.29 12.4 4 8.27 1 5.34l4.15-.6L7 1z"/></svg>
            <svg width="14" height="14" viewBox="0 0 14 14" fill="currentColor"><path d="M7 1l1.85 3.74 4.15.6-3 2.92.71 4.13L7 10.45 3.29 12.4 4 8.27 1 5.34l4.15-.6L7 1z"/></svg>
            <svg width="14" height="14" viewBox="0 0 14 14" fill="currentColor"><path d="M7 1l1.85 3.74 4.15.6-3 2.92.71 4.13L7 10.45 3.29 12.4 4 8.27 1 5.34l4.15-.6L7 1z"/></svg>
          </span>
          <span>{{ rating }} {{ trust_line }}</span>
        </p>
      {%- endif -%}
    </header>

    {%- if featured_block -%}
      <figure class="testimonial-feature reveal" {{ featured_block.shopify_attributes }}>
        <div class="stars" aria-hidden="true">
          {%- for i in (1..5) -%}
            <svg width="18" height="18" viewBox="0 0 14 14" fill="currentColor"><path d="M7 1l1.85 3.74 4.15.6-3 2.92.71 4.13L7 10.45 3.29 12.4 4 8.27 1 5.34l4.15-.6L7 1z"/></svg>
          {%- endfor -%}
        </div>
        <blockquote>{{ featured_block.settings.quote }}</blockquote>
        <figcaption>
          <span class="who">{{ featured_block.settings.name }}</span>
          {%- if featured_block.settings.location != blank -%}
            <span class="where">{{ featured_block.settings.location }}</span>
          {%- endif -%}
        </figcaption>
      </figure>
    {%- endif -%}

    <div class="testimonials-rail" role="list" aria-label="Customer reviews">
      {%- for block in section.blocks -%}
        {%- if featured_block and block.id == featured_block.id -%}{%- continue -%}{%- endif -%}
        <figure class="testimonial reveal{% if forloop.index > 1 %} reveal-d{{ forloop.index | minus: 1 | at_most: 4 }}{% endif %}" role="listitem" {{ block.shopify_attributes }}>
          <div class="stars" aria-hidden="true">
            {%- for i in (1..5) -%}
              <svg width="14" height="14" viewBox="0 0 14 14" fill="currentColor"><path d="M7 1l1.85 3.74 4.15.6-3 2.92.71 4.13L7 10.45 3.29 12.4 4 8.27 1 5.34l4.15-.6L7 1z"/></svg>
            {%- endfor -%}
          </div>
          <blockquote>{{ block.settings.quote }}</blockquote>
          <figcaption>
            <span class="who">{{ block.settings.name }}</span>
            {%- if block.settings.location != blank -%}
              <span class="where">{{ block.settings.location }}</span>
            {%- endif -%}
          </figcaption>
        </figure>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Testimonials",
  "settings": [
    { "type": "text", "id": "kicker", "label": "Kicker", "default": "Real quotes · names changed" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "From the people who actually use it." },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "These are real words from real customers. We swapped the names for privacy." },
    { "type": "text", "id": "rating", "label": "Average rating (e.g. 4.9)", "default": "4.9" },
    { "type": "text", "id": "trust_line", "label": "Trust line (after rating)", "default": "average · early customer reviews" }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        { "type": "textarea", "id": "quote", "label": "Quote" },
        { "type": "text", "id": "name", "label": "Name", "default": "Customer" },
        { "type": "text", "id": "location", "label": "Location", "default": "NC" },
        { "type": "checkbox", "id": "featured", "label": "Make this the featured (large) quote", "default": false }
      ]
    }
  ],
  "presets": [
    {
      "name": "Testimonials",
      "blocks": [
        { "type": "testimonial", "settings": { "quote": "The best surprise? It's great for the kids. They actually remember their chores — they come home, see the little guy is down, and can't make excuses anymore.", "name": "Marcus B.", "location": "Greensboro, NC", "featured": true } },
        { "type": "testimonial", "settings": { "quote": "I didn't think it'd be that useful, honestly. But now I really appreciate being able to glance from the house to see if trash or recycling has been picked up.", "name": "Sarah M.", "location": "Raleigh, NC", "featured": false } },
        { "type": "testimonial", "settings": { "quote": "Quality product — easy to use and really functional. I can see it from our second-story window, and since our trash and recycling trucks come at different times, I'd normally have no idea. Saves a walk in the rain.", "name": "Mike T.", "location": "Asheville, NC", "featured": false } },
        { "type": "testimonial", "settings": { "quote": "So convenient to just look outside and know if the truck came. And our daughters have loved setting up the little guy each week when we put the can at the curb.", "name": "Amanda R.", "location": "Chapel Hill, NC", "featured": false } },
        { "type": "testimonial", "settings": { "quote": "Really helpful — prevents an unnecessary trip down the driveway. I could see it being a lifesaver for anyone with mobility issues, or during a summer heat wave.", "name": "David K.", "location": "Charlotte, NC", "featured": false } },
        { "type": "testimonial", "settings": { "quote": "With our long driveway this thing is a lifesaver. I'm planning to get one for my mom — she's older and it'd be perfect for her.", "name": "Jen P.", "location": "Wilmington, NC", "featured": false } },
        { "type": "testimonial", "settings": { "quote": "It's like having a flag on the mailbox.", "name": "Tom H.", "location": "Durham, NC", "featured": false } }
      ]
    }
  ]
}
{% endschema %}
