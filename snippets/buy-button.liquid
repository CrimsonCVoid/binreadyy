{%- comment -%}
  Add-to-cart CTAs. Requires `product` in scope.
  Renders one button per variant (up to two, side by side).
  JS in theme.js handles AJAX submission.
{%- endcomment -%}

{%- assign product = product | default: all_products[section.settings.product] -%}
{%- if product == blank -%}
  <p>Select a product in the theme customizer.</p>
{%- else -%}
  {%- assign variants = product.variants -%}
  {%- assign primary = variants[0] -%}
  {%- assign secondary = variants[1] -%}

  <div class="buy-options" data-variant-count="{{ variants.size }}">
    {%- for variant in variants limit: 2 -%}
      <form class="js-add-to-cart buy-option {% if forloop.first %}buy-option-primary{% else %}buy-option-secondary{% endif %}" action="/cart/add" method="post">
        <input type="hidden" name="id" value="{{ variant.id }}" />
        <input type="hidden" name="quantity" value="1" />

        <div class="buy-option-meta">
          <span class="buy-option-name">{{ variant.title | default: 'Ready Eddie' }}</span>
          {%- if variant.compare_at_price > variant.price -%}
            <span class="buy-option-save">Save {{ variant.compare_at_price | minus: variant.price | money }}</span>
          {%- elsif forloop.last and variants.size > 1 -%}
            {%- assign per_unit_primary = primary.price -%}
            {%- assign assumed_units = 2 -%}
            {%- assign expected = per_unit_primary | times: assumed_units -%}
            {%- if variant.price < expected -%}
              {%- assign diff = expected | minus: variant.price -%}
              <span class="buy-option-save">Save {{ diff | money }}</span>
            {%- endif -%}
          {%- endif -%}
        </div>

        <button
          type="submit"
          class="btn btn-primary btn-buy {% unless forloop.first %}btn-buy-alt{% endunless %}"
          {% unless variant.available %}disabled{% endunless %}
        >
          {%- if variant.available -%}
            <span class="btn-buy-label">
              {%- if forloop.first -%}
                Add to cart
              {%- else -%}
                Buy 2-pack
              {%- endif -%}
            </span>
            <span class="btn-buy-divider" aria-hidden="true">&middot;</span>
            <span class="buy-price">{{ variant.price | money }}</span>
          {%- else -%}
            Sold out
          {%- endif -%}
        </button>
      </form>
    {%- endfor -%}
  </div>

  {% render 'reassure-list' %}
{%- endif -%}
