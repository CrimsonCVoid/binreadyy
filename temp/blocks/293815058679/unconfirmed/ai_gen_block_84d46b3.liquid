{% doc %}
  @prompt
    Modify the "Add to Cart" button behavior so that when a customer clicks it, they are immediately redirected to checkout instead of just adding to the cart with no visual feedback. The store sells a single product and wants a direct add-to-cart-then-checkout flow. This should work by either changing the form action to go directly to /checkout, or by adding JavaScript that redirects to /checkout after the item is added to the cart.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-checkout-button-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
  }

  .ai-checkout-button__form-{{ ai_gen_id }} {
    width: 100%;
  }

  .ai-checkout-button__button-{{ ai_gen_id }} {
    width: 100%;
    padding: {{ block.settings.button_padding }}px;
    background-color: {{ block.settings.button_color }};
    color: {{ block.settings.button_text_color }};
    border: none;
    border-radius: {{ block.settings.border_radius }}px;
    font-size: {{ block.settings.font_size }}px;
    font-weight: {{ block.settings.font_weight }};
    cursor: pointer;
    transition: background-color 0.3s ease;
    text-align: center;
  }

  .ai-checkout-button__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_color }};
  }

  .ai-checkout-button__button-{{ ai_gen_id }}:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }

  .ai-checkout-button__loading-{{ ai_gen_id }} {
    display: none;
    margin-left: 8px;
  }

  .ai-checkout-button__button-{{ ai_gen_id }}.loading .ai-checkout-button__loading-{{ ai_gen_id }} {
    display: inline-block;
  }

  @media screen and (max-width: 749px) {
    .ai-checkout-button-{{ ai_gen_id }} {
      width: 100%;
    }
  }
{% endstyle %}

<checkout-redirect-button-{{ ai_gen_id }}
  class="ai-checkout-button-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <form
    method="post"
    action="/cart/add"
    class="ai-checkout-button__form-{{ ai_gen_id }}"
    data-checkout-redirect-form
  >
    <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
    <input type="hidden" name="quantity" value="1">
    
    <button
      type="submit"
      class="ai-checkout-button__button-{{ ai_gen_id }}"
      {% unless product.selected_or_first_available_variant.available %}disabled{% endunless %}
    >
      {% if product.selected_or_first_available_variant.available %}
        {{ block.settings.button_text }}
      {% else %}
        {{ block.settings.sold_out_text }}
      {% endif %}
      <span class="ai-checkout-button__loading-{{ ai_gen_id }}">...</span>
    </button>
  </form>
</checkout-redirect-button-{{ ai_gen_id }}>

<script>
  (function() {
    class CheckoutRedirectButton{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.form = this.querySelector('[data-checkout-redirect-form]');
        this.button = this.querySelector('.ai-checkout-button__button-{{ ai_gen_id }}');
      }

      connectedCallback() {
        if (this.form) {
          this.form.addEventListener('submit', this.handleSubmit.bind(this));
        }
      }

      handleSubmit(event) {
        event.preventDefault();

        if (this.button.disabled) {
          return;
        }

        this.button.classList.add('loading');
        this.button.disabled = true;

        const formData = new FormData(this.form);

        fetch('/cart/add.js', {
          method: 'POST',
          body: formData
        })
        .then(response => response.json())
        .then(data => {
          window.location.href = '/checkout';
        })
        .catch(error => {
          console.error('Error adding to cart:', error);
          this.button.classList.remove('loading');
          this.button.disabled = false;
          alert('There was an error. Please try again.');
        });
      }
    }

    customElements.define('checkout-redirect-button-{{ ai_gen_id }}', CheckoutRedirectButton{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Buy now button",
  "settings": [
    {
      "type": "header",
      "content": "Button text"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Buy now"
    },
    {
      "type": "text",
      "id": "sold_out_text",
      "label": "Sold out text",
      "default": "Sold out"
    },
    {
      "type": "header",
      "content": "Button style"
    },
    {
      "type": "color",
      "id": "button_color",
      "label": "Background color",
      "default": "#F5612A"
    },
    {
      "type": "color",
      "id": "button_hover_color",
      "label": "Hover background color",
      "default": "#D94F1E"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "font_size",
      "label": "Font size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "select",
      "id": "font_weight",
      "label": "Font weight",
      "options": [
        {
          "value": "400",
          "label": "Normal"
        },
        {
          "value": "500",
          "label": "Medium"
        },
        {
          "value": "600",
          "label": "Semi-bold"
        },
        {
          "value": "700",
          "label": "Bold"
        }
      ],
      "default": "600"
    },
    {
      "type": "range",
      "id": "button_padding",
      "label": "Padding",
      "min": 8,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 50,
      "step": 2,
      "unit": "px",
      "default": 8
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    }
  ],
  "presets": [
    {
      "name": "Buy now button"
    }
  ]
}
{% endschema %}
